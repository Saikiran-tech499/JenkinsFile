pipeline {
    agent any

    stages {

        stage('newpipeline') {
            steps {
                build job: 'newpipeline'
            }
        }
    }
 }

    post {
        success {
            echo 'All jobs executed successfully.'
        }

        failure {
            echo 'Pipeline execution failed.'
        }

        always {
            echo 'Pipeline execution completed.'
        }
    }
}
